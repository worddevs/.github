# 🎀 Word Devs — GitAttributes Configuration
# Docs: https://git-scm.com/docs/gitattributes

# ---------------------------------------------------------------------------
# 🌍 Line Endings Normalization
# ---------------------------------------------------------------------------
# Handle line endings automatically for files detected as text
# and force them to LF when checked into the repository.
* text=auto eol=lf

# ---------------------------------------------------------------------------
# 📝 Specific Text File Overrides
# ---------------------------------------------------------------------------
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.html text eol=lf
.editorconfig text eol=lf
.gitignore text eol=lf

# ---------------------------------------------------------------------------
# 🖼️ Binary Files (Keep them exact, do not touch line endings)
# ---------------------------------------------------------------------------
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.mp3 binary
*.mp4 binary
*.woff binary
*.woff2 binary
*.ttf binary
