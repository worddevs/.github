# 🎀 Word Devs — GitIgnore Configuration
# Docs: https://git-scm.com/docs/gitignore

# ---------------------------------------------------------------------------
# 🔐 Secrets & Environment Variables (NEVER UPLOAD!)
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env
*.env.*
config.private.*
secrets.json

# ---------------------------------------------------------------------------
# 📦 Dependencies & Packages
# ---------------------------------------------------------------------------
node_modules/
jspm_packages/
.pnp/
.pnp.js

# ---------------------------------------------------------------------------
# 📁 Build & Production Outputs
# ---------------------------------------------------------------------------
dist/
build/
out/
.next/
.vuepress/dist
.docusaurus/
.svelte-kit/

# ---------------------------------------------------------------------------
# 📜 Logs and Debugging
# ---------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log
logs/
*.pid
*.seed
*.pid.lock

# ---------------------------------------------------------------------------
# 💻 Operating System & IDE Files
# ---------------------------------------------------------------------------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# IDEs (VS Code, WebStorm, etc.)
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---------------------------------------------------------------------------
# 🧪 Testing & Coverage
# ---------------------------------------------------------------------------
coverage/
.nyc_output/

# ---------------------------------------------------------------------------
# 🧩 Miscellaneous / Temporary
# ---------------------------------------------------------------------------
.eslintcache
.stylelintcache
.turbo/
.cache/
